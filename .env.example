# ─────────────────────────────────────────────────────────────────────────────
# PractoCore App — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the PocketBase backend (no trailing slash)
# Development:  http://127.0.0.1:8090
# Production:   https://api.practocore.com  (or your VPS IP/domain)
NUXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Android (Capacitor) LAN dev override — set to your machine's LAN IP
VITE_POCKETBASE_URL=http://192.168.1.x:8090

